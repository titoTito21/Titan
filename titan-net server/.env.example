# Titan-Net Server Configuration
# Copy this file to .env and adjust settings

# Server settings
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8001

HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Database
DATABASE_PATH=database/titannet.db

# File uploads
UPLOAD_DIR=uploads
# Max upload size in bytes. Default 1GB (1073741824). TCE packages can be large.
MAX_UPLOAD_SIZE=1073741824

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=change-this-in-production-to-random-string

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Mail server (email verification, password recovery, user mailboxes)
# MAIL_ENABLED=1 turns on outbound email. Sending goes through the local
# Postfix relay by default (SMTP_HOST=127.0.0.1, SMTP_PORT=25); point SMTP_*
# at an external relay instead if you are not self-hosting Postfix.
MAIL_ENABLED=0
# Domain that user identities live under (username@MAIL_DOMAIN).
MAIL_DOMAIN=titosofttitan.com
# Envelope/From address for system mail (verification, password reset).
MAIL_FROM=no-reply@titosofttitan.com
MAIL_FROM_NAME=Titan-Net
# Public base URL used to build verification/reset links.
MAIL_PUBLIC_URL=https://titosofttitan.com
# SMTP relay the app hands mail to.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
# Optional SMTP auth + TLS (leave blank for a local unauthenticated Postfix).
SMTP_USER=
SMTP_PASS=
SMTP_TLS=0
# Shared secret used by the Postfix delivery pipe to ingest inbound mail via
# the running server (POST /api/mail/incoming). Generate a random string, e.g.
# python -c "import secrets; print(secrets.token_urlsafe(32))"
MAIL_INGEST_TOKEN=
