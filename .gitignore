# Auto Claude data directory
.auto-claude/

# ===== Optimization profiling artifacts (Phase 0) =====
profile_out/
*.pstats
# Cython build artifacts under src/ (generated .pyd live next to .py;
# .c is the intermediate). Scoped to src/ so the legitimate data/lib/*.c
# (e.g. copilothook.c) is never ignored.
src/**/*.c
src/**/*.pyd

# ===== Secrets / credentials =====
# Environment files (DEPLOY_PASSWORD, TITAN_OAUTH_KEY, provider secrets)
.env
.env.local
.env.*.local
*.env
!.env.example

# Hardcoded-credential helper script (already leaked — rotate password)
refresh_token.py

# ElevenLabs API key (already leaked — rotate key)
data/applications/elevenlabs client TCE Version/%appdata%/Titosoft/Titan/Additional apps/elevenlabsclient.ini

# OAuth tokens / cached credentials
**/oauth_tokens.json
**/oauth_state.json
**/credentials.json
**/token.json

# Private keys
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_ed25519

# SSH deploy keypair (lives in titan-net server/.ssh/ — backed up via OneDrive,
# never committed)
titan-net server/.ssh/
**/titannet_deploy
**/titannet_deploy.pub
.ssh/

# ===== Titan-Net server runtime data =====
# Production + backup SQLCipher databases
titan-net server/database/
titan-net server/logs/

# Server PID lock
titan-net server/*.pid
**/titannet.db.pid

# ===== Personal deploy / update / recovery scripts =====
# Kept out of public repo (no secrets in source — they read from .env —
# but this is admin tooling, not part of the published codebase)
titan-net server/update.py
titan-net server/deploy.py
titan-net server/quick_update.py
titan-net server/local_backup.py
titan-net server/_oauth_install.py
titan-net server/_install_sqlcipher.py
titan-net server/_post_install_check.py
titan-net server/_recover_now.py
# Argon2id migration tooling (2026-05-07). _inject_dbkey.py in particular
# operates on the SQLCipher DATABASE_KEY value at runtime — it MUST stay
# out of the public repo. The other three only use DEPLOY_PASSWORD from
# .env, but they are personal admin tooling and not part of the published
# codebase either.
titan-net server/_install_argon2.py
titan-net server/_inject_dbkey.py
titan-net server/_smoke_check.py
titan-net server/_diag_env.py
# Personal admin scripts directory (2026-05-10) — SSH key migration,
# PPK generator, and any future admin tooling. Touches sshd_config and the
# deploy keypair; never publish.
titan-net server/scripts/

# ===== Build / compile artifacts =====
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg-info/
*.egg

# PyInstaller — output dirs at repo root + auto-generated spec
/build/
/dist/
*.spec
*.spec.bak
pyinstaller-build/
pyinstaller-dist/

# Nuitka — working dirs, standalone output, onefile temp, crash reports
*.build/
*.dist/
*.onefile-build/
*.onefile-temp/
*.onefile-*.tmp
*.exp
*.lib
nuitka-crash-report.xml
compiled/
release/

# Cython / C extension intermediates from compilation
*.c.tmp
*.cpp.tmp

# Compile / debug logs
compile_log.txt
engine_registry_debug.log
**/component_debug*.log
**/app_manager_debug*.log
blog_read_debug.txt
*.log

# ===== Editor / IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code workspace (commands, settings, locks) — kept locally only
.claude/
**/.claude/

# ===== OS noise =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Local user data (per-user app state) =====
# Apps store runtime config under simulated %appdata%
data/applications/**/%appdata%/

# ===== Bundled TTS engine binaries (kept locally only — large + licensed) =====
data/titantts engines/

# ===== Vendored deps for the Titan Talk gamepad mode (large; pip-installed) =====
data/gamepad/modes/titan_talk/lib/
data/gamepad/modes/*/__pycache__/

# ===== Sound themes (only ship "default"; other themes are local-only) =====
sfx/*/
!sfx/default/
