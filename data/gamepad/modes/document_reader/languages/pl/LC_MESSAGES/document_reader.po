msgid ""
"Document reader. Up and down read lines, left and right spell characters, A "
"reads to the end. Bumpers switch between text field and clipboard."
msgstr ""
"Czytnik dokumentów. Góra i dół czytają linie, lewo i prawo literują znaki, A "
"czyta do końca. Bumpery przełączają między polem tekstowym a schowkiem."

msgid "Not in a text field"
msgstr "Poza polem tekstowym"

msgid "Text field"
msgstr "Pole tekstowe"

msgid "Clipboard"
msgstr "Schowek"

msgid "Blank"
msgstr "Pusty"

msgid "Space"
msgstr "Spacja"

msgid "New line"
msgstr "Nowa linia"

msgid "Tab"
msgstr "Tabulator"

msgid "Blank line"
msgstr "Pusta linia"

msgid "End of document"
msgstr "Koniec dokumentu"
